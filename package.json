{
  "name": "welford-containers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Clean-room browser-native Node-like runtime foundation for Welford Containers.",
  "exports": {
    "./webcontainer": "./packages/embed/dist/webcontainer-compatible.js",
    "./packages/embed/dist/webcontainer-compatible.js": "./packages/embed/dist/webcontainer-compatible.js"
  },
  "scripts": {
